# =============================================================================
# Secrets template
# =============================================================================
# Copy this file to `secrets.toml` (without the .example) and fill in real values.
# IMPORTANT: secrets.toml is gitignored — it never gets committed.
#
# In Streamlit Community Cloud, paste the contents of secrets.toml into:
# App settings → Secrets → paste TOML contents
# =============================================================================

# Password to enter the dashboard. Share this with the 101 Advisors team.
# Change before going to production.
dashboard_password = "demo101"

# (Future) Google Sheets service account credentials — for when collectors are wired
# [gcp_service_account]
# type = "service_account"
# project_id = "..."
# private_key_id = "..."
# private_key = "..."
# client_email = "..."
# client_id = "..."

# (Future) BatchSkipTracing API key
# batch_skip_api_key = "..."

# (Future) Miami-Dade Commercial Data API key
# miami_dade_api_key = "..."
